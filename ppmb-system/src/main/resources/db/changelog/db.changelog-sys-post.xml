<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260502-1" author="jules">
        <createTable tableName="sys_post">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="post_code" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="post_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="sort_num" type="INT"/>
            <column name="status" type="TINYINT" defaultValue="0"/>
            <column name="remark" type="VARCHAR(255)"/>

            <column name="create_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="create_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="create_by_dept" type="BIGINT"/>
            <column name="update_by" type="BIGINT"/>
            <column name="update_time" type="TIMESTAMP"/>
            <column name="del_flag" type="INT" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="INT" defaultValue="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
