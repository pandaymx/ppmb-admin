<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="20260503-003" author="jules">
        <createTable tableName="sys_error_log">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="request_url" type="VARCHAR(512)"/>
            <column name="http_method" type="VARCHAR(16)"/>
            <column name="client_ip" type="VARCHAR(128)"/>
            <column name="user_agent" type="VARCHAR(1024)"/>
            <column name="request_params" type="TEXT"/>

            <column name="operator_id" type="BIGINT"/>
            <column name="operator_account" type="VARCHAR(64)"/>

            <column name="class_name" type="VARCHAR(255)"/>
            <column name="method_name" type="VARCHAR(255)"/>
            <column name="exception_type" type="VARCHAR(255)"/>
            <column name="error_message" type="TEXT"/>
            <column name="stack_trace" type="TEXT"/>

            <column name="create_by" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="create_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="create_by_dept" type="BIGINT"/>
            <column name="update_by" type="BIGINT"/>
            <column name="update_time" type="TIMESTAMP"/>
            <column name="del_flag" type="INT" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="INT" defaultValue="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
