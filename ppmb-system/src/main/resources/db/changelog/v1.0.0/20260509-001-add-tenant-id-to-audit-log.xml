<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

  <changeSet id="20260509-001-add-tenant-id-to-audit-log" author="antigravity">
    <addColumn tableName="sys_audit_log">
      <column name="tenant_id" type="BIGINT" defaultValueNumeric="0" remarks="租户 ID">
        <constraints nullable="false"/>
      </column>
      <column name="create_by" type="BIGINT" defaultValueNumeric="0" remarks="创建者 ID">
          <constraints nullable="false"/>
      </column>
      <column name="dept_id" type="BIGINT" defaultValueNumeric="0" remarks="部门 ID">
          <constraints nullable="false"/>
      </column>
      <column name="role_id" type="BIGINT" defaultValueNumeric="0" remarks="角色 ID">
          <constraints nullable="false"/>
      </column>
      <column name="data_scope" type="INT" defaultValueNumeric="0" remarks="数据范围">
          <constraints nullable="false"/>
      </column>
    </addColumn>
    
    <createIndex tableName="sys_audit_log" indexName="idx_sys_audit_log_tenant_id">
      <column name="tenant_id"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
