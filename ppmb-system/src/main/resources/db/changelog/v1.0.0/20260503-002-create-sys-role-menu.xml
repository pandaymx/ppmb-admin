<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="20260503-002" author="jules">
        <createTable tableName="sys_role_menu" remarks="Role and Menu Association Table">
            <column name="id" type="BIGINT" remarks="Primary Key">
                <constraints primaryKey="true" primaryKeyName="pk_sys_role_menu"/>
            </column>
            <column name="role_id" type="BIGINT" remarks="Role ID">
                <constraints nullable="false"/>
            </column>
            <column name="menu_id" type="BIGINT" remarks="Menu ID">
                <constraints nullable="false"/>
            </column>
            <column name="create_by" type="BIGINT" remarks="Creator ID"/>
            <column name="create_time" type="TIMESTAMP" remarks="Creation Time"/>
            <column name="update_by" type="BIGINT" remarks="Updater ID"/>
            <column name="update_time" type="TIMESTAMP" remarks="Update Time"/>
            <!-- Uses physical deletion as per child entity guidelines so no del_flag -->
        </createTable>

        <createIndex tableName="sys_role_menu" indexName="idx_sys_role_menu_role_id_menu_id" unique="true">
            <column name="role_id"/>
            <column name="menu_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
